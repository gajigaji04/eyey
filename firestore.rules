rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 각 사용자는 자기 자신의 설정/일정 문서만 읽고 쓸 수 있다.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /days/{date} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
